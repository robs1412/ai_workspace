<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.koval.macmini-network-watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/admin/bin/koval-macmini-network-watchdog.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>StandardOutPath</key>
  <string>/Users/admin/Library/Logs/koval-macmini-network-watchdog.out</string>
  <key>StandardErrorPath</key>
  <string>/Users/admin/Library/Logs/koval-macmini-network-watchdog.err</string>
</dict>
</plist>
